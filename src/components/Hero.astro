---
import { copy, media, v2, type Locale } from "../content/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const hero = copy[locale].hero;
const scrollCue = v2[locale].scrollCue;

// Split the headline into words and tag the emphasis phrase so it can be
// animated word-by-word and accented in italic brass.
const words = [
  ...hero.titleLead.split(" ").map((w) => ({ w, accent: false })),
  ...hero.titleEmphasis.split(" ").map((w) => ({ w, accent: true })),
  ...hero.titleTail.split(" ").map((w) => ({ w, accent: false })),
];

// Force the headline onto two lines (feedback: "What is holding" / "you back?").
// Break right after the first emphasis word.
const breakAfter = hero.titleLead.split(" ").length;
---

<section class="hero" id="basecamp" data-altitude>
  <div class="hero__sticky">
    <div
      class="hero__fallback"
      style={media.heroImageUrl ? `--hero-image: url("${media.heroImageUrl}")` : undefined}
      role="img"
      aria-label={hero.imageAlt}
    >
    </div>
    <canvas class="hero__canvas" data-hero-canvas data-hero-src={media.heroImageUrl} aria-hidden="true"></canvas>
    <div class="hero__grad" aria-hidden="true"></div>

    <div class="hero__content">
      <div class="hero__crest">
        <img src="/FOUNDERS-UNIVERSITY.svg" alt="Founders University" />
      </div>
      <h1>
        {
          words.map((item, i) => (
            <Fragment>
              <span class="word">
                <span style={`--w: ${i}`}>{item.accent ? <em>{item.w}</em> : item.w}</span>
              </span>
              {i === breakAfter && <br class="hero__break" />}
            </Fragment>
          ))
        }
      </h1>
    </div>

    <div class="hero__cue" aria-hidden="true">
      <span>{scrollCue}</span>
      <span class="hero__cue-line"></span>
    </div>
  </div>
</section>

<script>
  const canvas = document.querySelector("[data-hero-canvas]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canvas instanceof HTMLCanvasElement && !reduce) {
    const gl =
      canvas.getContext("webgl", { antialias: false, alpha: false, powerPreference: "high-performance" }) ||
      canvas.getContext("experimental-webgl");

    if (gl && gl instanceof WebGLRenderingContext) {
      const VERT = `
        attribute vec2 p;
        void main(){ gl_Position = vec4(p, 0.0, 1.0); }
      `;

      const FRAG = `
        precision highp float;
        uniform vec2 u_res;
        uniform float u_time;
        uniform vec2 u_mouse;
        uniform float u_scroll;
        uniform sampler2D u_tex;
        uniform float u_imgAspect;
        uniform float u_hasTex;

        float hash(vec2 p){ return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123); }
        float noise(vec2 p){
          vec2 i = floor(p), f = fract(p);
          vec2 u = f * f * (3.0 - 2.0 * f);
          return mix(mix(hash(i), hash(i + vec2(1.0, 0.0)), u.x),
                     mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);
        }
        float fbm(vec2 p){
          float v = 0.0, a = 0.5;
          mat2 m = mat2(1.6, 1.2, -1.2, 1.6);
          for (int i = 0; i < 6; i++){ v += a * noise(p); p = m * p; a *= 0.5; }
          return v;
        }
        vec2 coverUV(vec2 uv, float sa, float ia){
          vec2 t = uv - 0.5;
          if (sa > ia) { t.y *= ia / sa; } else { t.x *= sa / ia; }
          return t + 0.5;
        }

        void main(){
          vec2 uv = gl_FragCoord.xy / u_res;
          float sa = u_res.x / u_res.y;
          vec2 m = (u_mouse - 0.5);

          float zoom = 1.0 + u_scroll * 0.18;
          vec2 cuv = coverUV(uv, sa, u_imgAspect);
          cuv = (cuv - 0.5) / zoom + 0.5;
          cuv += m * 0.022;

          vec3 img;
          if (u_hasTex > 0.5) { img = texture2D(u_tex, cuv).rgb; }
          else { img = mix(vec3(0.05, 0.08, 0.09), vec3(0.10, 0.15, 0.17), uv.y); }

          // editorial grade: lift slate shadows, warm highlights
          img = pow(img, vec3(1.04));
          img *= vec3(1.05, 1.0, 0.93);

          // brass light shaft from upper-right
          vec2 lp = vec2(0.68, 0.16);
          float d = distance(uv, lp);
          vec2 dir = normalize(uv - lp + 0.0001);
          float ray = fbm(uv * 3.0 + dir * 2.5 - u_time * 0.02);
          float shaft = smoothstep(0.95, 0.0, d) * (0.35 + 0.55 * ray);
          img += vec3(0.86, 0.62, 0.32) * shaft * 0.5;

          // rising cloud-inversion fog, intensifying with scroll
          float f1 = fbm(vec2(uv.x * 2.2, uv.y * 2.2) + vec2(u_time * 0.015, -u_time * 0.05));
          float f2 = fbm(vec2(uv.x * 4.6 + 11.0, uv.y * 3.6) + vec2(-u_time * 0.02, -u_time * 0.085));
          float fog = f1 * 0.6 + f2 * 0.4;
          float mask = smoothstep(0.92, 0.12, uv.y);
          float amt = clamp(mask * 0.55 + u_scroll * 0.95, 0.0, 1.35);
          float f = clamp(fog * amt, 0.0, 1.0);
          vec3 fogCol = mix(vec3(0.60, 0.64, 0.69), vec3(0.80, 0.75, 0.66), uv.y);
          img = mix(img, fogCol, f * 0.85);

          // descend into the dark as the hero is scrolled
          img = mix(img, vec3(0.027, 0.035, 0.039), smoothstep(0.5, 1.0, u_scroll));

          // vignette + film grain
          float vig = smoothstep(1.15, 0.32, distance(uv, vec2(0.5)));
          img *= mix(0.66, 1.0, vig);
          img += (hash(uv * u_res.xy * 0.5 + u_time) - 0.5) * 0.045;

          gl_FragColor = vec4(img, 1.0);
        }
      `;

      const compile = (type: number, src: string) => {
        const sh = gl.createShader(type)!;
        gl.shaderSource(sh, src);
        gl.compileShader(sh);
        if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) {
          console.warn("hero shader:", gl.getShaderInfoLog(sh));
          return null;
        }
        return sh;
      };

      const vs = compile(gl.VERTEX_SHADER, VERT);
      const fs = compile(gl.FRAGMENT_SHADER, FRAG);

      if (vs && fs) {
        const prog = gl.createProgram()!;
        gl.attachShader(prog, vs);
        gl.attachShader(prog, fs);
        gl.linkProgram(prog);
        gl.useProgram(prog);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
        const loc = gl.getAttribLocation(prog, "p");
        gl.enableVertexAttribArray(loc);
        gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

        const U = {
          res: gl.getUniformLocation(prog, "u_res"),
          time: gl.getUniformLocation(prog, "u_time"),
          mouse: gl.getUniformLocation(prog, "u_mouse"),
          scroll: gl.getUniformLocation(prog, "u_scroll"),
          tex: gl.getUniformLocation(prog, "u_tex"),
          imgAspect: gl.getUniformLocation(prog, "u_imgAspect"),
          hasTex: gl.getUniformLocation(prog, "u_hasTex"),
        };

        // 1x1 placeholder until the photo arrives
        const tex = gl.createTexture();
        gl.bindTexture(gl.TEXTURE_2D, tex);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, new Uint8Array([20, 30, 34, 255]));
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
        gl.uniform1i(U.tex, 0);
        gl.uniform1f(U.hasTex, 0);
        gl.uniform1f(U.imgAspect, 1.0);

        const src = canvas.getAttribute("data-hero-src");
        if (src) {
          const img = new Image();
          img.crossOrigin = "anonymous";
          img.onload = () => {
            gl.bindTexture(gl.TEXTURE_2D, tex);
            gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
            gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, img);
            gl.uniform1f(U.hasTex, 1);
            gl.uniform1f(U.imgAspect, img.width / img.height);
            canvas.classList.add("is-ready");
          };
          img.src = src;
        } else {
          canvas.classList.add("is-ready");
        }

        let mx = 0.5,
          my = 0.5,
          tmx = 0.5,
          tmy = 0.5;
        addEventListener(
          "pointermove",
          (e) => {
            tmx = e.clientX / innerWidth;
            tmy = 1 - e.clientY / innerHeight;
          },
          { passive: true },
        );

        const heroEl = document.querySelector(".hero") as HTMLElement | null;
        const dpr = Math.min(devicePixelRatio || 1, 2);
        const resize = () => {
          const w = Math.floor(canvas.clientWidth * dpr);
          const h = Math.floor(canvas.clientHeight * dpr);
          if (canvas.width !== w || canvas.height !== h) {
            canvas.width = w;
            canvas.height = h;
          }
          gl.viewport(0, 0, canvas.width, canvas.height);
        };
        addEventListener("resize", resize);
        resize();

        const t0 = performance.now();
        let raf = 0;
        const render = (now: number) => {
          const heroH = heroEl ? heroEl.offsetHeight : innerHeight;
          const prog = Math.min(1, Math.max(0, scrollY / Math.max(1, heroH - innerHeight)));
          // pause work once the hero has fully scrolled away
          if (scrollY > heroH + innerHeight) {
            raf = requestAnimationFrame(render);
            return;
          }
          mx += (tmx - mx) * 0.05;
          my += (tmy - my) * 0.05;
          resize();
          gl.uniform2f(U.res, canvas.width, canvas.height);
          gl.uniform1f(U.time, (now - t0) / 1000);
          gl.uniform2f(U.mouse, mx, my);
          gl.uniform1f(U.scroll, prog);
          gl.drawArrays(gl.TRIANGLES, 0, 3);
          raf = requestAnimationFrame(render);
        };
        const start = () => {
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(render);
        };
        const stop = () => cancelAnimationFrame(raf);
        document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
        start();
      }
    }
  }
</script>
