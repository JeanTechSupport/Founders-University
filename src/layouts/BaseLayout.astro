---
import "../styles/global.css";
import { brand, localeSettings, showDutch, v2, type Locale } from "../content/site";

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const path = locale === "en" ? "/" : "/nl/";
const altHref = locale === "en" ? "/nl/" : "/";
const t = v2[locale];
---

<!doctype html>
<html lang={localeSettings[locale].lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0b07" />
    {!showDutch && locale === "nl" && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={new URL(path, Astro.site)} />
    <link rel="alternate" hreflang={locale} href={new URL(path, Astro.site)} />
    {showDutch && (
      <link rel="alternate" hreflang={locale === "en" ? "nl" : "en"} href={new URL(altHref, Astro.site)} />
    )}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(path, Astro.site)} />
    <meta property="og:image" content={new URL("/og-card.svg", Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-card.svg", Astro.site)} />
    <link rel="icon" href="/favicon-eagle.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/spacegrotesk-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/spacegrotesk-500.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/Mountain.png" as="image" />
  </head>
  <body>
    <!-- Intro loader -->
    <div class="loader" data-loader aria-hidden="true">
      <img class="loader__crest" src="/Founders-university icon.svg" alt="" />
      <span class="loader__word"><span>{t.loaderTagline}</span></span>
      <span class="loader__bar"><span></span></span>
    </div>

    <slot />

    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const body = document.body;

      /* ---- Loader -------------------------------------------------------- */
      const loader = document.querySelector("[data-loader]");
      const bar = loader?.querySelector(".loader__bar span");
      const finish = () => {
        body.classList.add("v2-ready");
        loader?.classList.add("is-done");
      };
      if (loader && bar instanceof HTMLElement && !reduce) {
        let p = 0;
        const tick = window.setInterval(() => {
          p = Math.min(0.9, p + Math.random() * 0.16 + 0.04);
          bar.style.setProperty("--progress", String(p));
        }, 170);
        const done = () => {
          window.clearInterval(tick);
          bar.style.setProperty("--progress", "1");
          window.setTimeout(finish, 360);
        };
        if (document.readyState === "complete") done();
        else window.addEventListener("load", done, { once: true });
        window.setTimeout(done, 2600);
      } else {
        finish();
      }

      /* ---- Reveal on scroll ---------------------------------------------- */
      const revealIO = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) {
              en.target.classList.add("is-visible");
              revealIO.unobserve(en.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => revealIO.observe(el));

      /* ---- Count-up stats ------------------------------------------------ */
      const countIO = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (!en.isIntersecting || !(en.target instanceof HTMLElement)) return;
            countIO.unobserve(en.target);
            const el = en.target;
            const raw = el.getAttribute("data-count") || "";
            const m = raw.match(/([\d.,]+)/);
            if (!m || reduce) {
              el.textContent = raw;
              return;
            }
            const numStr = m[1];
            const target = parseFloat(numStr.replace(/,/g, ""));
            const idx = m.index || 0;
            const prefix = raw.slice(0, idx);
            const suffix = raw.slice(idx + numStr.length);
            const start = performance.now();
            const step = (now: number) => {
              const t = Math.min(1, (now - start) / 1500);
              const e = 1 - Math.pow(1 - t, 3);
              el.textContent = prefix + Math.round(target * e) + suffix;
              if (t < 1) requestAnimationFrame(step);
              else el.textContent = raw;
            };
            requestAnimationFrame(step);
          });
        },
        { threshold: 0.6 },
      );
      document.querySelectorAll("[data-count]").forEach((el) => countIO.observe(el));

      /* ---- Altitude rail ------------------------------------------------- */
      const railItems = Array.from(document.querySelectorAll(".altitude__item"));
      const sections = Array.from(document.querySelectorAll("[data-altitude]"));
      if (railItems.length && sections.length) {
        const sectionIO = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (!en.isIntersecting) return;
              const id = en.target.getAttribute("id");
              railItems.forEach((it) =>
                it.classList.toggle("is-active", it.getAttribute("data-target") === "#" + id),
              );
            });
          },
          { rootMargin: "-45% 0px -45% 0px" },
        );
        sections.forEach((s) => sectionIO.observe(s));
        railItems.forEach((it) =>
          it.addEventListener("click", () => {
            const sel = it.getAttribute("data-target");
            const el = sel ? document.querySelector(sel) : null;
            el?.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
          }),
        );
      }

      /* ---- FAQ accordion ------------------------------------------------- */
      document.querySelectorAll(".faq__item").forEach((item) => {
        const q = item.querySelector(".faq__q");
        const a = item.querySelector(".faq__a");
        if (!(q instanceof HTMLElement) || !(a instanceof HTMLElement)) return;
        q.addEventListener("click", () => {
          const open = item.classList.toggle("is-open");
          q.setAttribute("aria-expanded", String(open));
          a.style.height = open ? a.scrollHeight + "px" : "0px";
        });
      });
      addEventListener("resize", () => {
        document.querySelectorAll(".faq__item.is-open .faq__a").forEach((a) => {
          if (a instanceof HTMLElement) a.style.height = a.scrollHeight + "px";
        });
      });

      /* ---- Back to top --------------------------------------------------- */
      document.querySelector(".to-top")?.addEventListener("click", () => {
        scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
      });

      /* ---- Unified scroll loop (header, cta, parallax, manifesto) -------- */
      const header = document.querySelector(".v2-header");
      const altitude = document.querySelector(".altitude");
      const mobileCta = document.querySelector(".mobile-cta");
      const pricing = document.querySelector("#enrollment");
      const footer = document.querySelector(".v2-footer");
      const parallaxEls = Array.from(document.querySelectorAll("[data-parallax]"));

      let ticking = false;
      const update = () => {
        ticking = false;
        const y = scrollY;
        const vh = innerHeight;
        const past = y > vh * 0.7;
        header?.classList.toggle("is-visible", past);
        altitude?.classList.toggle("is-visible", past);

        if (mobileCta) {
          let show = y > vh * 1.6;
          [pricing, footer].forEach((s) => {
            if (!s) return;
            const b = s.getBoundingClientRect();
            if (b.top < vh && b.bottom > 0) show = false;
          });
          mobileCta.classList.toggle("is-visible", show);
        }

        if (!reduce) {
          parallaxEls.forEach((el) => {
            if (!(el instanceof HTMLElement)) return;
            const speed = parseFloat(el.getAttribute("data-parallax") || "0.1");
            const r = el.getBoundingClientRect();
            const center = r.top + r.height / 2;
            const off = (center - vh / 2) * speed * -1;
            el.style.transform = `translate3d(0, ${off.toFixed(1)}px, 0)`;
          });
        }
      };
      const onScroll = () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      };
      addEventListener("scroll", onScroll, { passive: true });
      addEventListener("resize", onScroll);
      update();

      /* ---- Manifesto: auto-play the word-fill when it enters view -------- */
      const manifesto = document.querySelector(".manifesto");
      if (manifesto) {
        const words = Array.from(manifesto.querySelectorAll(".mword"));
        const play = () => {
          if (reduce) {
            words.forEach((w) => w.classList.add("is-lit"));
            return;
          }
          words.forEach((w, i) => window.setTimeout(() => w.classList.add("is-lit"), i * 95));
        };
        const mIO = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                play();
                mIO.disconnect();
              }
            });
          },
          { threshold: 0.35 },
        );
        mIO.observe(manifesto);
      }

      /* ---- Countdown to a real deadline --------------------------------- */
      document.querySelectorAll("[data-countdown]").forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const target = new Date(el.getAttribute("data-countdown") || "").getTime();
        if (Number.isNaN(target)) {
          el.remove();
          return;
        }
        const ended = el.getAttribute("data-cd-ended") || "";
        const pad = (n: number) => String(n).padStart(2, "0");
        const set = (k: string, v: number) => {
          const node = el.querySelector(`[data-cd="${k}"]`);
          if (node) node.textContent = pad(v);
        };
        const tick = () => {
          let diff = Math.floor((target - Date.now()) / 1000);
          if (diff <= 0) {
            const cap = el.querySelector(".countdown__caption");
            const clock = el.querySelector(".countdown__clock");
            if (cap) cap.textContent = ended;
            if (clock instanceof HTMLElement) clock.style.display = "none";
            window.clearInterval(timer);
            return;
          }
          const d = Math.floor(diff / 86400);
          diff -= d * 86400;
          const h = Math.floor(diff / 3600);
          diff -= h * 3600;
          const m = Math.floor(diff / 60);
          set("days", d);
          set("hours", h);
          set("minutes", m);
          set("seconds", diff - m * 60);
        };
        const timer = window.setInterval(tick, 1000);
        tick();
      });

      /* ---- Benefits carousel: auto-rotate, pause on hover --------------- */
      document.querySelectorAll("[data-carousel]").forEach((root) => {
        if (!(root instanceof HTMLElement)) return;
        const track = root.querySelector("[data-carousel-track]");
        if (!(track instanceof HTMLElement)) return;
        const slides = Array.from(track.children);
        const dotsWrap = root.querySelector("[data-carousel-dots]");
        if (!slides.length) return;

        const perView = () => (innerWidth <= 640 ? 1 : innerWidth <= 1080 ? 2 : 3);
        let index = 0;
        const maxIndex = () => Math.max(0, slides.length - perView());

        const render = () => {
          index = Math.min(index, maxIndex());
          const first = slides[0];
          const gap = parseFloat(getComputedStyle(track).columnGap || "0") || 0;
          const step = (first instanceof HTMLElement ? first.offsetWidth : 0) + gap;
          track.style.transform = `translate3d(${-index * step}px, 0, 0)`;
          dots.forEach((d, i) => d.classList.toggle("is-active", i === index));
        };
        const next = () => {
          index = index >= maxIndex() ? 0 : index + 1;
          render();
        };
        const prev = () => {
          index = index <= 0 ? maxIndex() : index - 1;
          render();
        };

        let auto = 0;
        const start = () => {
          if (!reduce) auto = window.setInterval(next, 4200);
        };
        const stop = () => window.clearInterval(auto);
        const restart = () => {
          stop();
          start();
        };

        const dots: HTMLButtonElement[] = [];
        if (dotsWrap instanceof HTMLElement) {
          dotsWrap.innerHTML = "";
          for (let i = 0; i <= maxIndex(); i++) {
            const b = document.createElement("button");
            b.className = "carousel__dot";
            b.type = "button";
            b.setAttribute("aria-label", `Go to slide ${i + 1}`);
            b.addEventListener("click", () => {
              index = i;
              render();
              restart();
            });
            dotsWrap.appendChild(b);
            dots.push(b);
          }
        }

        root.querySelector("[data-carousel-next]")?.addEventListener("click", () => {
          next();
          restart();
        });
        root.querySelector("[data-carousel-prev]")?.addEventListener("click", () => {
          prev();
          restart();
        });
        root.addEventListener("pointerenter", stop);
        root.addEventListener("pointerleave", start);
        addEventListener("resize", render);

        render();
        start();
      });
    </script>
  </body>
</html>
